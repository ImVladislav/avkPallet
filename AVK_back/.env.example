PORT=3001
# Опційно: через кому, повний Origin фронту (https://your-app.vercel.app).
# Якщо не задавати — сервер дозволяє запити з будь-якого домену (рефлексія Origin).
# CORS_ORIGINS=https://your-app.vercel.app
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Або можна задати COMPASS=<URI> — сервер теж підхопить.
# Обхід TLS "internal error" до Atlas на Windows вже в коді (IPv4 + autoSelectFamily).
# Якщо потрібен IPv6: MONGODB_DUAL_STACK=1
# На Linux/macOS за потреби: MONGODB_FORCE_IPV4=1
